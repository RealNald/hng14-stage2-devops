# .env.example – placeholder for required environment variables
# Copy this file to .env and adjust values if needed.
# DO NOT commit the actual .env file.

# Redis connection (used by API and worker)
REDIS_HOST=redis
REDIS_PORT=6379

# API URL for frontend (internal Docker service name)
API_URL=http://api:8000

# Optional: override frontend listen port
FRONTEND_PORT=3000

# Optional: logging level
LOG_LEVEL=info
